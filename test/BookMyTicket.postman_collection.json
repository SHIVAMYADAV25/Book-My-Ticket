    {
      "name": "💺 SEATS",
      "item": [

        {
          "name": "Get All Seats for a Show",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  const available = json.data.filter(s => !s.isBooked);",
            "  if (available.length > 0) {",
            "    pm.collectionVariables.set('seatId', available[0].id);",
            "    console.log('✅ Saved seatId (first available):', available[0].id, '—', available[0].seatNumber);",
            "    console.log('   Total seats:', json.data.length);",
            "    console.log('   Available:', available.length);",
            "    console.log('   Booked:', json.data.length - available.length);",
            "  }",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/movies/shows/{{showId}}/seats",
              "host": ["{{base_url}}"],
              "path": ["movies","shows","{{showId}}","seats"]
            }
          }
        },

        {
          "name": "Get Available Seats Only",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
